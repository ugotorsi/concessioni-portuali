model Ente {
  id           String             @id @default(cuid())
  nome         String
  codice       String             @unique
  tipo         EnteTipo           @default(ALTRO)
  stato        EnteStato          @default(ATTIVO)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  concessioni  Concessione[]
  documenti    Documento[]
  report       Report[]
  activityLog  ActivityLog[]
  memberships  TenantMembership[]
  ports        Port[]
  legalSources LegalSource[]
  legalRules   LegalRule[]
  documentGaps DocumentGap[]
  importRuns   ImportRun[]

  @@index([tipo])
  @@index([stato])
  @@index([createdAt])
}

model Authority {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  level     AuthorityLevel @default(ALTRO)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  ports        Port[]
  legalSources LegalSource[]
  importRuns   ImportRun[]

  @@index([level])
  @@index([createdAt])
}

model Port {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  enteId      String?
  authorityId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ente         Ente?         @relation(fields: [enteId], references: [id], onDelete: SetNull)
  authority    Authority?    @relation(fields: [authorityId], references: [id], onDelete: SetNull)
  areas        PortArea[]
  legalSources LegalSource[]
  legalRules   LegalRule[]
  documentGaps DocumentGap[]
  importRuns   ImportRun[]

  @@index([enteId])
  @@index([authorityId])
  @@index([createdAt])
}

model PortArea {
  id        String   @id @default(cuid())
  portId    String
  code      String
  name      String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  port Port @relation(fields: [portId], references: [id], onDelete: Cascade)

  @@unique([portId, code])
  @@index([portId])
  @@index([createdAt])
}

model ImportRun {
  id            String          @id @default(cuid())
  packCode      String
  packVersion   String
  manifestPath  String
  status        ImportRunStatus @default(IN_PROGRESS)
  sourceCount   Int             @default(0)
  ruleCount     Int             @default(0)
  relationCount Int             @default(0)
  gapCount      Int             @default(0)
  warnings      Json?
  errorMessage  String?
  enteId        String?
  authorityId   String?
  portId        String?
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ente         Ente?         @relation(fields: [enteId], references: [id], onDelete: SetNull)
  authority    Authority?    @relation(fields: [authorityId], references: [id], onDelete: SetNull)
  port         Port?         @relation(fields: [portId], references: [id], onDelete: SetNull)
  legalSources LegalSource[]

  @@index([packCode])
  @@index([status])
  @@index([enteId])
  @@index([createdAt])
}

model LegalSource {
  id                   String                @id @default(cuid())
  sourceKey            String                @unique
  title                String
  sourceType           LegalSourceType
  status               LegalSourceStatus     @default(CURRENT_SUBJECT_TO_REVIEW)
  role                 LegalSourceRole       @default(NORMATIVE)
  legalRank            LegalRank             @default(OTHER)
  territorialScope     LegalTerritorialScope @default(AUTHORITY)
  confidence           LegalSourceConfidence @default(MEDIUM)
  issuingBody          String?
  sourceNumber         String?
  sourceDate           DateTime?
  sourceOrigin         String?
  portAreaCode         String?
  tags                 Json?
  humanReviewRequired  Boolean               @default(true)
  isConformative       Boolean               @default(true)
  isExtractable        Boolean               @default(true)
  duplicateOfSourceKey String?
  publicationDate      DateTime?
  effectiveFrom        DateTime?
  effectiveTo          DateTime?
  notes                String?
  fileName             String?
  filePath             String?
  fileChecksumSha256   String?
  fileMimeType         String?
  fileSizeBytes        Int?
  enteId               String?
  authorityId          String?
  portId               String?
  importRunId          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  ente              Ente?            @relation(fields: [enteId], references: [id], onDelete: SetNull)
  authority         Authority?       @relation(fields: [authorityId], references: [id], onDelete: SetNull)
  port              Port?            @relation(fields: [portId], references: [id], onDelete: SetNull)
  importRun         ImportRun?       @relation(fields: [importRunId], references: [id], onDelete: SetNull)
  rules             LegalRule[]
  outgoingRelations SourceRelation[] @relation("SourceRelationFrom")
  incomingRelations SourceRelation[] @relation("SourceRelationTo")

  @@index([sourceType])
  @@index([status])
  @@index([role])
  @@index([legalRank])
  @@index([territorialScope])
  @@index([confidence])
  @@index([isConformative])
  @@index([isExtractable])
  @@index([enteId])
  @@index([portId])
  @@index([effectiveFrom])
  @@index([createdAt])
}

model SourceRelation {
  id           String             @id @default(cuid())
  fromSourceId String
  toSourceId   String
  relationType SourceRelationType
  note         String?
  createdAt    DateTime           @default(now())

  fromSource LegalSource @relation("SourceRelationFrom", fields: [fromSourceId], references: [id], onDelete: Cascade)
  toSource   LegalSource @relation("SourceRelationTo", fields: [toSourceId], references: [id], onDelete: Cascade)

  @@unique([fromSourceId, toSourceId, relationType])
  @@index([fromSourceId])
  @@index([toSourceId])
  @@index([relationType])
}

model LegalRule {
  id                      String                      @id @default(cuid())
  sourceId                String
  ruleCode                String
  title                   String
  summary                 String
  category                LegalRuleCategory
  status                  LegalRuleStatus             @default(ATTIVA)
  priority                Int                         @default(100)
  enteId                  String?
  portId                  String?
  matchConcessionVertical ConcessionVertical?
  matchObjectType         ConcessionObjectType?
  matchAttivita           AttivitaConcessione?
  matchAwardingProcedure  AwardingProcedureType?
  matchFeeRegime          FeeRegime?
  matchComparativeStatus  ComparativeProcedureStatus?
  requiresRilevanzaArt47  Boolean?
  matchArt47Letter        Art47CodNavLettera?
  requiresMorosita        Boolean?
  requiresPolizzaValida   Boolean?
  outputSeverity          GravitaCriticita            @default(MEDIA)
  outcomeTitle            String
  outcomeSummary          String
  disclaimer              String?
  humanReviewRequired     Boolean                     @default(true)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  source       LegalSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  ente         Ente?         @relation(fields: [enteId], references: [id], onDelete: SetNull)
  port         Port?         @relation(fields: [portId], references: [id], onDelete: SetNull)
  documentGaps DocumentGap[]

  @@unique([sourceId, ruleCode])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([enteId])
  @@index([portId])
  @@index([matchConcessionVertical])
  @@index([createdAt])
}

model DocumentGap {
  id                    String            @id @default(cuid())
  gapKey                String            @unique
  title                 String
  description           String
  severity              GravitaCriticita  @default(MEDIA)
  status                DocumentGapStatus @default(APERTA)
  requiredDocumentTypes Json?
  notes                 String?
  humanReviewRequired   Boolean           @default(true)
  enteId                String?
  portId                String?
  ruleId                String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  ente Ente?      @relation(fields: [enteId], references: [id], onDelete: SetNull)
  port Port?      @relation(fields: [portId], references: [id], onDelete: SetNull)
  rule LegalRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity])
  @@index([enteId])
  @@index([portId])
  @@index([ruleId])
  @@index([createdAt])
}

model TenantMembership {
  id        String    @id @default(cuid())
  userId    String
  enteId    String
  role      RuoloUser
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ente Ente @relation(fields: [enteId], references: [id], onDelete: Cascade)

  @@unique([userId, enteId])
  @@index([userId])
  @@index([enteId])
  @@index([isDefault])
  @@index([role])
}

model User {
  id                  String             @id @default(cuid())
  nome                String
  email               String             @unique
  passwordHash        String?
  ruolo               RuoloUser
  attivo              Boolean            @default(true)
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?
  lastFailedLoginAt   DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?
  mustChangePassword  Boolean            @default(false)
  mfaEnabled          Boolean            @default(false)
  mfaSecret           String?
  mfaRecoveryCodes    Json?
  mfaVerifiedAt       DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  activityLogs        ActivityLog[]
  documentiCaricati   Documento[]        @relation("DocumentoUploader")
  tenantMemberships   TenantMembership[]

  @@index([ruolo])
  @@index([attivo])
  @@index([lockedUntil])
  @@index([mfaEnabled])
  @@index([mustChangePassword])
  @@index([createdAt])
}

model Concessionario {
  id                   String        @id @default(cuid())
  denominazione        String
  codiceFiscale        String?
  partitaIva           String?
  sedeLegale           String?
  pec                  String?
  legaleRappresentante String?
  telefono             String?
  email                String?
  note                 String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  concessioni          Concessione[]

  @@index([denominazione])
  @@index([createdAt])
}

model Concessione {
  id                         String                     @id @default(cuid())
  numeroAtto                 String
  dataRilascio               DateTime
  dataScadenza               DateTime
  normaRiferimento           NormaRiferimento
  tipologiaBene              TipologiaBene
  attivita                   AttivitaConcessione
  superficieMq               Decimal?
  latitudineGis              Decimal?
  longitudineGis             Decimal?
  coordinateGis              String?
  areaDescrizione            String?
  zonaPortuale               String?
  riferimentoCatastale       String?
  canoneAnnuo                Decimal?
  categoriaCanone            String?
  concessionVertical         ConcessionVertical         @default(PORTUALE_ADSP)
  concessionObjectType       ConcessionObjectType?
  awardingProcedureType      AwardingProcedureType      @default(ALTRO)
  removableWorksProfile      RemovableWorksProfile      @default(NON_RILEVATO)
  seasonalityProfile         SeasonalityProfile         @default(NON_RILEVATO)
  feeRegime                  FeeRegime                  @default(ALTRO)
  comparativeProcedureStatus ComparativeProcedureStatus @default(NON_APPLICABILE)
  thirdPartyManagementStatus ThirdPartyManagementStatus @default(DIRETTA)
  stato                      StatoConcessione
  descrizioneBene            String?
  ubicazione                 String?
  note                       String?
  concessionarioId           String
  enteId                     String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  concessionario  Concessionario              @relation(fields: [concessionarioId], references: [id], onDelete: Restrict)
  ente            Ente?                       @relation(fields: [enteId], references: [id], onDelete: SetNull)
  obblighi        ObbligoConcessorio[]
  scadenze        Scadenza[]
  criticita       Criticita[]
  procedimenti    Procedimento[]
  sopralluoghi    Sopralluogo[]
  pagamenti       Pagamento[]
  documenti       Documento[]
  report          Report[]
  legalFrameworks ConcessioneLegalFramework[]
  normaImpatti    NormaImpatto[]
  activityLogs    ActivityLog[]

  @@index([stato])
  @@index([dataScadenza])
  @@index([concessionarioId])
  @@index([enteId])
  @@index([tipologiaBene])
  @@index([zonaPortuale])
  @@index([concessionVertical])
  @@index([concessionObjectType])
  @@index([awardingProcedureType])
  @@index([feeRegime])
  @@index([comparativeProcedureStatus])
  @@index([thirdPartyManagementStatus])
  @@index([latitudineGis, longitudineGis])
  @@index([createdAt])
}

model ConcessioneLegalFramework {
  id            String         @id @default(cuid())
  concessioneId String
  framework     LegalFramework
  note          String?
  createdAt     DateTime       @default(now())

  concessione Concessione @relation(fields: [concessioneId], references: [id], onDelete: Cascade)

  @@unique([concessioneId, framework])
  @@index([concessioneId])
  @@index([framework])
  @@index([createdAt])
}

model ObbligoConcessorio {
  id                   String           @id @default(cuid())
  concessioneId        String
  tipologia            TipologiaObbligo
  fonte                String?
  descrizione          String
  frequenza            String?
  dataProssimaVerifica DateTime?
  stato                StatoObbligo
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  concessione Concessione @relation(fields: [concessioneId], references: [id], onDelete: Cascade)

  @@index([concessioneId])
  @@index([stato])
  @@index([tipologia])
  @@index([dataProssimaVerifica])
  @@index([createdAt])
}

model Scadenza {
  id              String            @id @default(cuid())
  concessioneId   String
  tipologia       TipologiaScadenza
  dataScadenza    DateTime
  preavvisoGiorni Int               @default(30)
  stato           StatoScadenza
  descrizione     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  concessione Concessione @relation(fields: [concessioneId], references: [id], onDelete: Cascade)

  @@index([concessioneId])
  @@index([stato])
  @@index([tipologia])
  @@index([dataScadenza])
  @@index([createdAt])
}

model Criticita {
  id                           String                   @id @default(cuid())
  concessioneId                String
  tipologia                    TipologiaCriticita
  gravita                      GravitaCriticita
  fonte                        FonteCriticita
  descrizione                  String
  riferimentoNormativo         String?
  azioneConsigliata            String?
  latitudineGis                Decimal?
  longitudineGis               Decimal?
  localizzazioneDescrizione    String?
  rilevanzaArt47               Boolean                  @default(false)
  letteraArt47                 Art47CodNavLettera?
  rischioDecadenza             LivelloRischioDecadenza?
  motivazioneArt47             String?
  azioneIstruttoriaArt47       String?
  regolarizzata                Boolean                  @default(false)
  dataRegolarizzazione         DateTime?
  descrizioneRegolarizzazione  String?
  esitoRegolarizzazione        EsitoRegolarizzazione?
  verificataRegolarizzazione   Boolean                  @default(false)
  dataVerificaRegolarizzazione DateTime?
  noteVerificaRegolarizzazione String?
  stato                        StatoCriticita
  dataRilevazione              DateTime                 @default(now())
  dataUltimoAggiornamento      DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt

  concessione  Concessione    @relation(fields: [concessioneId], references: [id], onDelete: Cascade)
  procedimenti Procedimento[]
  documenti    Documento[]
  normaImpatti NormaImpatto[]

  @@index([concessioneId])
  @@index([stato])
  @@index([gravita])
  @@index([tipologia])
  @@index([latitudineGis, longitudineGis])
  @@index([rilevanzaArt47])
  @@index([letteraArt47])
  @@index([rischioDecadenza])
  @@index([regolarizzata])
  @@index([dataRegolarizzazione])
  @@index([esitoRegolarizzazione])
  @@index([verificataRegolarizzazione])
  @@index([dataRilevazione])
  @@index([createdAt])
}

model Procedimento {
  id                               String                        @id @default(cuid())
  concessioneId                    String
  criticitaId                      String?
  tipologia                        TipologiaProcedimento
  origineProcedimento              OrigineProcedimento           @default(UFFICIO)
  procedimentoUfficio              Boolean                       @default(true)
  riferimentoNormativo             String?
  dataAvvio                        DateTime?
  dataScadenzaContraddittorio      DateTime?
  dataProvvedimentoFinale          DateTime?
  comunicazioneAvvioInviata        Boolean                       @default(false)
  dataComunicazioneAvvio           DateTime?
  termineMemorieGiorni             Int?
  termineMemorieScadenza           DateTime?
  memorieRicevute                  Boolean                       @default(false)
  dataRicezioneMemorie             DateTime?
  audizioneRichiesta               Boolean                       @default(false)
  audizioneSvolta                  Boolean                       @default(false)
  dataAudizione                    DateTime?
  sopralluogoIstruttorioSvolto     Boolean                       @default(false)
  contestazioneFormaleInviata      Boolean                       @default(false)
  dataContestazioneFormale         DateTime?
  controdeduzioniValutate          Boolean                       @default(false)
  motivazioneValutazione           String?
  propostaEsitoIstruttorio         EsitoIstruttorioProcedimento?
  preavvisoRigettoApplicabile      Boolean                       @default(false)
  statoPreavvisoRigetto            StatoPreavvisoRigetto         @default(NON_VALUTATO)
  dataPreavvisoRigetto             DateTime?
  termineOsservazioniPreavviso     DateTime?
  osservazioniPreavvisoRicevute    Boolean                       @default(false)
  dataOsservazioniPreavviso        DateTime?
  valutazioneOsservazioniPreavviso String?
  motivazioneMancatoPreavviso      String?
  checklistProfile                 ChecklistProfile              @default(CORE)
  checklistContraddittorioCompleta Boolean                       @default(false)
  noteChecklistContraddittorio     String?
  stato                            StatoProcedimento
  noteIstruttorie                  String?
  createdAt                        DateTime                      @default(now())
  updatedAt                        DateTime                      @updatedAt

  concessione  Concessione    @relation(fields: [concessioneId], references: [id], onDelete: Cascade)
  criticita    Criticita?     @relation(fields: [criticitaId], references: [id], onDelete: SetNull)
  documenti    Documento[]
  normaImpatti NormaImpatto[]

  @@index([concessioneId])
  @@index([criticitaId])
  @@index([stato])
  @@index([tipologia])
  @@index([origineProcedimento])
  @@index([procedimentoUfficio])
  @@index([preavvisoRigettoApplicabile])
  @@index([statoPreavvisoRigetto])
  @@index([checklistProfile])
  @@index([dataScadenzaContraddittorio])
  @@index([checklistContraddittorioCompleta])
  @@index([termineMemorieScadenza])
  @@index([contestazioneFormaleInviata])
  @@index([createdAt])
}

model Sopralluogo {
  id                        String           @id @default(cuid())
  concessioneId             String
  data                      DateTime
  operatori                 String
  esito                     EsitoSopralluogo
  conformitaPlanimetrica    Boolean          @default(false)
  latitudineGis             Decimal?
  longitudineGis            Decimal?
  localizzazioneDescrizione String?
  statoManutentivo          String?
  sicurezza                 String?
  occupazione               String?
  interferenze              String?
  descrizione               String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  concessione Concessione @relation(fields: [concessioneId], references: [id], onDelete: Cascade)
  documenti   Documento[]

  @@index([concessioneId])
  @@index([data])
  @@index([esito])
  @@index([latitudineGis, longitudineGis])
  @@index([createdAt])
}

model Pagamento {
  id              String         @id @default(cuid())
  concessioneId   String
  annoRiferimento Int
  importoDovuto   Decimal
  importoVersato  Decimal        @default(0)
  dataScadenza    DateTime
  dataVersamento  DateTime?
  stato           StatoPagamento
  interessiMora   Decimal?
  note            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  concessione Concessione @relation(fields: [concessioneId], references: [id], onDelete: Cascade)
  documenti   Documento[]

  @@index([concessioneId])
  @@index([stato])
  @@index([dataScadenza])
  @@index([annoRiferimento])
  @@index([createdAt])
}

model Documento {
  id                        String              @id @default(cuid())
  nome                      String
  tipologia                 TipologiaDocumento
  statoDocumento            StatoDocumento      @default(ATTIVO)
  direzione                 DocumentoDirezione?
  canale                    DocumentoCanale?
  numeroProtocollo          String?
  dataProtocollo            DateTime?
  mittente                  String?
  destinatario              String?
  pecMessageId              String?
  pecRicevutaAccettazioneId String?
  pecRicevutaConsegnaId     String?
  pecWarningMancataRicevuta Boolean             @default(false)
  mimeType                  String?
  dimensioneBytes           Int?
  checksumSha256            String?
  sha256                    String?
  url                       String?
  storagePath               String?
  storageKey                String?
  storageProvider           String?
  storageBucket             String?
  publicUrl                 String?
  nomeStorage               String?
  originalName              String?
  sizeBytes                 Int?
  documentType              String?
  documentDate              DateTime?
  source                    String?
  status                    String?
  dataDocumento             DateTime?
  descrizione               String?
  uploadedByUserId          String?
  uploadedByUserEmail       String?
  uploadedByUserRole        String?
  archivedAt                DateTime?
  enteId                    String?
  concessioneId             String?
  criticitaId               String?
  procedimentoId            String?
  sopralluogoId             String?
  pagamentoId               String?
  reportId                  String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  uploadedByUser User?         @relation("DocumentoUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  ente           Ente?         @relation(fields: [enteId], references: [id], onDelete: SetNull)
  concessione    Concessione?  @relation(fields: [concessioneId], references: [id], onDelete: SetNull)
  criticita      Criticita?    @relation(fields: [criticitaId], references: [id], onDelete: SetNull)
  procedimento   Procedimento? @relation(fields: [procedimentoId], references: [id], onDelete: SetNull)
  sopralluogo    Sopralluogo?  @relation(fields: [sopralluogoId], references: [id], onDelete: SetNull)
  pagamento      Pagamento?    @relation(fields: [pagamentoId], references: [id], onDelete: SetNull)
  report         Report?       @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([uploadedByUserId])
  @@index([statoDocumento])
  @@index([enteId])
  @@index([concessioneId])
  @@index([criticitaId])
  @@index([procedimentoId])
  @@index([sopralluogoId])
  @@index([pagamentoId])
  @@index([reportId])
  @@index([tipologia])
  @@index([direzione])
  @@index([canale])
  @@index([numeroProtocollo])
  @@index([dataProtocollo])
  @@index([pecWarningMancataRicevuta])
  @@index([dataDocumento])
  @@index([createdAt])
}

model Report {
  id            String          @id @default(cuid())
  enteId        String?
  concessioneId String?
  tipologia     TipologiaReport
  titolo        String
  contenuto     String
  formato       String          @default("PDF")
  validato      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  ente         Ente?          @relation(fields: [enteId], references: [id], onDelete: SetNull)
  concessione  Concessione?   @relation(fields: [concessioneId], references: [id], onDelete: SetNull)
  documenti    Documento[]
  normaImpatti NormaImpatto[]

  @@index([enteId])
  @@index([concessioneId])
  @@index([tipologia])
  @@index([validato])
  @@index([createdAt])
}

model NormaFonte {
  id            String      @id @default(cuid())
  codice        String      @unique
  titolo        String
  enteEmittente String?
  ambito        NormaAmbito
  descrizione   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  versioni NormaVersione[]
  impatti  NormaImpatto[]

  @@index([ambito])
  @@index([titolo])
  @@index([createdAt])
}

model NormaVersione {
  id                String             @id @default(cuid())
  normaFonteId      String
  versione          String
  stato             StatoNormaVersione
  dataEntrataVigore DateTime
  dataFineVigore    DateTime?
  urlTesto          String?
  sintesi           String
  note              String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  normaFonte NormaFonte     @relation(fields: [normaFonteId], references: [id], onDelete: Cascade)
  impatti    NormaImpatto[]

  @@unique([normaFonteId, versione])
  @@index([normaFonteId])
  @@index([stato])
  @@index([dataEntrataVigore])
  @@index([createdAt])
}

model NormaImpatto {
  id              String             @id @default(cuid())
  normaFonteId    String
  normaVersioneId String?
  modulo          ModuloImpattoNorma
  severita        GravitaCriticita   @default(MEDIA)
  descrizione     String
  azioneRichiesta String?
  concessioneId   String?
  criticitaId     String?
  procedimentoId  String?
  reportId        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  normaFonte    NormaFonte     @relation(fields: [normaFonteId], references: [id], onDelete: Cascade)
  normaVersione NormaVersione? @relation(fields: [normaVersioneId], references: [id], onDelete: SetNull)
  concessione   Concessione?   @relation(fields: [concessioneId], references: [id], onDelete: SetNull)
  criticita     Criticita?     @relation(fields: [criticitaId], references: [id], onDelete: SetNull)
  procedimento  Procedimento?  @relation(fields: [procedimentoId], references: [id], onDelete: SetNull)
  report        Report?        @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([normaFonteId])
  @@index([normaVersioneId])
  @@index([modulo])
  @@index([severita])
  @@index([criticitaId])
  @@index([procedimentoId])
  @@index([reportId])
  @@index([concessioneId])
  @@index([createdAt])
}

model ActivityLog {
  id            String     @id @default(cuid())
  userId        String?
  userEmail     String?
  userRole      String?
  enteId        String?
  concessioneId String?
  ipAddress     String?
  userAgent     String?
  azione        String
  entita        String
  entitaId      String?
  esito         AuditEsito @default(SUCCESS)
  metadata      Json?
  previousHash  String?
  currentHash   String
  createdAt     DateTime   @default(now())

  ente        Ente?        @relation(fields: [enteId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  concessione Concessione? @relation(fields: [concessioneId], references: [id], onDelete: SetNull)

  @@index([currentHash])
  @@index([userId])
  @@index([enteId])
  @@index([entita, entitaId])
  @@index([concessioneId])
  @@index([createdAt])
}
